# This file is an example of the .env.test.local file. Copy this to .env.test.local and fill in the values to run the tests.

# Redis example using an unsecured local instance.
# on macOS: brew install redis
REDIS_URL='redis://localhost:6379'

# Postgres example using Neon. You can create a free Neon account and database at https://neon.tech.
POSTGRES_URL='postgresql://neondb_owner:PASSWORD@URL/neondb?sslmode=require&channel_binding=require'